# Copy this file to .env and add only the credentials used by your Run Profile.
# Never commit .env or private voice-reference files.

# OpenAI: text, web research, image generation, and visual review.
OPENAI_API_KEY=

# Google Gemini: text, grounded research, image generation, and visual review.
GEMINI_API_KEY=

# ElevenLabs: cloud narration, timestamps, and optional music.
ELEVENLABS_API_KEY=
# Your authorized voice clone. A nonempty value overrides the blank TOML setting.
ELEVENLABS_VOICE_ID=

# Hugging Face: required only for gated local model downloads.
HF_TOKEN=

# Optional legacy Brave override. Curated local/mixed profiles use keyless DDGS search.
BRAVE_SEARCH_API_KEY=

# Optional Remotion stock media. Pexels is tried after media-library/ and Wikimedia Commons.
PEXELS_API_KEY=
# Wikimedia requires a real descriptive User-Agent with contact information; no API key is needed.
# Example: video-generator/0.1 (contact: maintainer@example.org)
WIKIMEDIA_USER_AGENT=

# Tenor was discontinued in June 2026. GIPHY is intentionally not integrated because its ordinary
# API terms do not grant the durable local caching/proxy workflow this renderer requires.
